# Copier ce fichier en .env et renseigner les valeurs
# .env est dans .gitignore — ne jamais committer les vrais secrets

# Source de données : mock | parquet | csv | sql | elasticsearch
DATA_SOURCE=mock

# Si DATA_SOURCE=parquet
PARQUET_PATH=logs_export.parquet

# Si DATA_SOURCE=csv
CSV_PATH=/chemin/vers/logs_iptables.csv

# Si DATA_SOURCE=sql
SQL_URL=postgresql://user:password@localhost:5432/opsie
SQL_QUERY=SELECT * FROM iptables_logs

# Si DATA_SOURCE=elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=iptables-logs
ES_SIZE=10000

# Clés API (onglet IA & ML)
MISTRAL_API_KEY=your_mistral_api_key_here
